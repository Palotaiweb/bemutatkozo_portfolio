# Környezeti változók – Palotai Dániel AI Portfólió

# =======================================================
# APPWRITE (publikus – frontend JS-ben is biztonságos)
# =======================================================
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=YOUR_PROJECT_ID_HERE

# =======================================================
# NETLIFY FUNCTION (privát – csak Netlify dashboardon!)
# Soha ne commitold ezeket a tényleges értékekkel!
# =======================================================
APPWRITE_API_KEY=YOUR_APPWRITE_SERVER_API_KEY
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-YOUR_OPENAI_OR_ANTHROPIC_KEY

# =======================================================
# MEGJEGYZÉSEK
# =======================================================
# LLM_PROVIDER: "openai" vagy "claude"
# LLM_MODEL (openai): "gpt-4o", "gpt-4o-mini"
# LLM_MODEL (claude): "claude-3-5-sonnet-20241022", "claude-3-haiku-20240307"
#
# Az APPWRITE_PROJECT_ID-t az index.html-ben a window.ENV-en
# keresztül kell átadni a frontendnek (nincs .env fájl a kliensnél):
#
# <script>
#   window.ENV = {
#     APPWRITE_ENDPOINT: "https://cloud.appwrite.io/v1",
#     APPWRITE_PROJECT_ID: "your-project-id"
#   };
# </script>
